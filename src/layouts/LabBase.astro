---
// src/layouts/LabBase.astro
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Polarity Lab internal.' } = Astro.props;

const labTabs = [
  { href: '/lab#now', label: 'Now' },
  { href: '/lab#roles', label: 'Roles' },
  { href: '/lab#grants', label: 'Grants' },
  { href: '/lab#context', label: 'Context' },
];

const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title === 'Polarity Lab' ? 'Polarity Lab' : `${title} | Polarity Lab`}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <nav class="lab-nav">
      <a href="/lab" class="lab-nav-back" title="Polarity HQ">
        <svg viewBox="0 0 100 100" aria-hidden="true" class="logo-atom">
          <defs>
            <radialGradient id="labNavGrad" cx="30%" cy="30%" r="70%">
              <stop offset="0%" stop-color="#6EE7DF"/>
              <stop offset="50%" stop-color="#4ECDC4"/>
              <stop offset="100%" stop-color="#2BA89F"/>
            </radialGradient>
            <filter id="labNavGlow" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="2" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
          <ellipse cx="50" cy="50" rx="40" ry="12" fill="none" stroke="#4ECDC4" stroke-width="1.5" transform="rotate(-60 50 50)" filter="url(#labNavGlow)" opacity="0.9"/>
          <ellipse cx="50" cy="50" rx="40" ry="12" fill="none" stroke="#FFA07A" stroke-width="1.5" transform="rotate(60 50 50)" filter="url(#labNavGlow)" opacity="0.9"/>
          <ellipse cx="50" cy="50" rx="40" ry="12" fill="none" stroke="#BB8FCE" stroke-width="1.5" filter="url(#labNavGlow)" opacity="0.9"/>
          <circle cx="70" cy="15" r="4" fill="#4ECDC4" filter="url(#labNavGlow)"/>
          <circle cx="30" cy="15" r="4" fill="#FFA07A" filter="url(#labNavGlow)"/>
          <circle cx="90" cy="50" r="4" fill="#BB8FCE" filter="url(#labNavGlow)"/>
          <circle cx="50" cy="50" r="14" fill="url(#labNavGrad)" filter="url(#labNavGlow)"/>
          <circle cx="45" cy="45" r="5" fill="white" opacity="0.25"/>
        </svg>
        <span class="lab-wordmark">POLARITY HQ</span>
      </a>

      <ul class="lab-nav-links" id="lab-nav-links">
        {labTabs.map(tab => (
          <li>
            <a
              href={tab.href}
              class:list={['lab-nav-link', { active: currentPath === '/lab' }]}
              data-tab={tab.label.toLowerCase()}
            >
              {tab.label}
            </a>
          </li>
        ))}
      </ul>

      <button class="hamburger" id="lab-hamburger" aria-label="Toggle navigation" aria-expanded="false" aria-controls="lab-nav-links">
        <svg class="icon-menu" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg class="icon-close" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="lab-footer">
      <span>Polarity Lab — Internal</span>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --void-pure: #000000;
    --void-deep: #020204;
    --void-space: #050508;
    --void-nebula: #080810;
    --void-surface: #0c0c14;
    --void-elevated: #12121c;
    --bg-nav: rgba(2, 2, 4, 0.92);
    --teal: #4ECDC4;
    --teal-bright: #5EEEE4;
    --teal-light: #7EFFF5;
    --teal-deep: #2BA89F;
    --teal-glow: rgba(78, 205, 196, 0.5);
    --teal-subtle: rgba(78, 205, 196, 0.12);
    --teal-border: rgba(78, 205, 196, 0.2);
    --coral: #FF6B6B;
    --coral-glow: rgba(255, 107, 107, 0.4);
    --purple: #BB8FCE;
    --purple-border: rgba(187, 143, 206, 0.2);
    --text-pure: rgba(255, 255, 255, 0.98);
    --text-primary: rgba(255, 255, 255, 0.88);
    --text-secondary: rgba(255, 255, 255, 0.65);
    --text-tertiary: rgba(255, 255, 255, 0.45);
    --text-ghost: rgba(255, 255, 255, 0.28);
    --border-ghost: rgba(255, 255, 255, 0.04);
    --border-subtle: rgba(255, 255, 255, 0.08);
    --border-medium: rgba(255, 255, 255, 0.15);
    --font-display: 'Space Grotesk', sans-serif;
    --font-body: 'Inter', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
    --ease-smooth: cubic-bezier(0.4, 0, 0.2, 1);
    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    background: var(--void-deep);
    color: var(--text-secondary);
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
  }

  body { background: var(--void-deep); min-height: 100vh; }
  a { text-decoration: none; color: inherit; }
  ul { list-style: none; }
  button { cursor: pointer; }

  ::selection {
    background: rgba(78, 205, 196, 0.2);
    color: var(--text-pure);
  }
</style>

<style>
  .lab-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2rem;
    border-bottom: 1px solid var(--border-ghost);
    position: sticky;
    top: 0;
    background: var(--bg-nav);
    backdrop-filter: blur(12px);
    z-index: 100;
  }

  .lab-nav-back {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .logo-atom {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    filter: drop-shadow(0 0 6px var(--teal-glow));
    transition: transform 0.6s var(--ease-out-expo);
  }

  .lab-nav-back:hover .logo-atom {
    transform: rotate(180deg);
  }

  .lab-wordmark {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-ghost);
    letter-spacing: 0.12em;
  }

  .lab-nav-back:hover .lab-wordmark {
    color: var(--text-secondary);
  }

  .lab-nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
  }

  .lab-nav-link {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-ghost);
    padding: 0.375rem 0.75rem;
    border-radius: 4px;
    transition: color 0.15s var(--ease-smooth), background 0.15s var(--ease-smooth);
    letter-spacing: 0.02em;
  }

  .lab-nav-link:hover {
    color: var(--text-primary);
    background: rgba(255,255,255,0.04);
  }

  .lab-nav-link.tab-active {
    color: var(--teal);
    background: var(--teal-subtle);
  }

  .hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: rgba(255,255,255,0.65);
    line-height: 0;
  }

  .icon-close { display: none; }

  .hamburger[aria-expanded="true"] .icon-menu { display: none; }
  .hamburger[aria-expanded="true"] .icon-close { display: block; }

  .lab-footer {
    padding: 2rem;
    border-top: 1px solid var(--border-ghost);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-ghost);
    letter-spacing: 0.05em;
  }

  @media (max-width: 640px) {
    .hamburger { display: flex; }

    .lab-nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      background: var(--void-surface);
      border-bottom: 1px solid var(--border-ghost);
      padding: 0.75rem 1.5rem 1.25rem;
    }

    .lab-nav-links.open { display: flex; }

    .lab-nav-links li { width: 100%; }

    .lab-nav-link {
      display: block;
      padding: 0.625rem 0;
      border-radius: 0;
      border-bottom: 1px solid var(--border-ghost);
    }
  }
</style>

<script>
  const hamburger = document.getElementById('lab-hamburger');
  const navLinks = document.getElementById('lab-nav-links');

  hamburger?.addEventListener('click', () => {
    const expanded = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!expanded));
    navLinks?.classList.toggle('open');
  });

  // Highlight active tab in nav based on current hash or active tab
  function updateNavActive(tabName: string) {
    document.querySelectorAll('.lab-nav-link').forEach(link => {
      const linkTab = (link as HTMLElement).dataset.tab;
      link.classList.toggle('tab-active', linkTab === tabName);
    });
  }

  // On /lab page, sync with tab state
  const activeTab = document.querySelector('.tab.active');
  if (activeTab) {
    updateNavActive((activeTab as HTMLElement).dataset.tab || 'now');
  }

  // Listen for tab changes (dispatched by lab.astro tab script)
  document.addEventListener('lab:tabchange', (e: Event) => {
    updateNavActive((e as CustomEvent).detail);
  });

  // Sync on hash change
  window.addEventListener('hashchange', () => {
    const hash = window.location.hash.replace('#', '');
    if (hash) updateNavActive(hash);
  });
</script>

---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found" description="This page does not exist.">
  <div class="not-found">
    <p class="code">404</p>
    <p class="message">This page does not exist.</p>
    <a href="/">Back to Polarity Lab</a>
  </div>
</Base>

<style>
  .not-found {
    max-width: 720px;
    margin: 0 auto;
    padding: 8rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .code {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-ghost);
  }

  .message {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: var(--text-pure);
  }
</style>

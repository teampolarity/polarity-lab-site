</style>

<script>
  const CORRECT = '2025';
  const STORAGE_KEY = 'pl_lab_auth';

  const gate = document.getElementById('gate');
  const content = document.getElementById('lab-content');
  const input = document.getElementById('gate-input') as HTMLInputElement;
  const error = document.getElementById('gate-error');

  function unlock() {
    if (gate) (gate as HTMLElement).style.display = 'none';
    if (content) (content as HTMLElement).style.display = 'block';
    localStorage.setItem(STORAGE_KEY, '1');
  }

  if (localStorage.getItem(STORAGE_KEY) === '1') {
    unlock();
  }

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      if (input.value === CORRECT) {
        unlock();
      } else {
        if (error) error.textContent = 'Incorrect.';
        input.value = '';
      }
    }
  });

  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab');
  const panels = document.querySelectorAll<HTMLElement>('.tab-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      panels.forEach(p => p.setAttribute('hidden', ''));
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      document.getElementById(`panel-${target}`)?.removeAttribute('hidden');
    });
  });
</script>

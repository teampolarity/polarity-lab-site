---
import { getCollection, render } from 'astro:content';
import LabBase from '../../../layouts/LabBase.astro';

export async function getStaticPaths() {
  const grants = await getCollection('grants');
  return grants.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const statusLabels: Record<string, string> = {
  'loi-in-progress': 'LOI in progress',
  'in-development': 'In development',
  'submitted': 'Submitted',
  'funded': 'Funded',
};
---
<LabBase title={entry.data.title} description={`${entry.data.title} — Polarity Lab`}>
  <div class="gate" id="gate">
    <form id="gate-form" autocomplete="off">
      <label for="gate-input">Polarity Lab</label>
      <input type="password" id="gate-input" placeholder="Access code" autocomplete="new-password" />
      <p class="gate-error" id="gate-error" aria-live="polite"></p>
    </form>
  </div>

  <div class="doc-page" id="doc-content" hidden>
    <div class="doc-header">
      <p class="breadcrumb"><a href="/lab">Lab</a> / <a href="/lab#grants">Grants</a></p>
      <h1>{entry.data.title}</h1>
      <div class="doc-meta">
        {entry.data.funder && <span class="doc-funder">{entry.data.funder}</span>}
        {entry.data.program && <span class="doc-sep">/</span>}
        {entry.data.program && <span class="doc-program">{entry.data.program.toUpperCase()}</span>}
        {entry.data.status && (
          <span class={`doc-status ${entry.data.status === 'loi-in-progress' ? 'status-active' : 'status-dev'}`}>
            {statusLabels[entry.data.status] ?? entry.data.status}
          </span>
        )}
      </div>
    </div>

    <div class="doc-body">
      <Content />
    </div>
  </div>
</LabBase>

<style>
  /* Gate */
  .gate {
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #gate-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
    max-width: 320px;
    padding: 2rem;
  }

  #gate-form label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.05em;
    color: var(--text-pure);
    text-transform: uppercase;
  }

  #gate-input {
    width: 100%;
    background: var(--void-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: 4px;
    padding: 0.75rem 1rem;
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--text-pure);
    text-align: center;
    letter-spacing: 0.1em;
    outline: none;
    transition: border-color 0.2s var(--ease-smooth);
  }

  #gate-input:focus { border-color: var(--teal); }

  .gate-error {
    font-size: 0.8125rem;
    color: var(--coral);
    font-family: var(--font-mono);
    min-height: 1.2em;
  }

  /* Doc page */
  .doc-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
  }

  .doc-header {
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border-ghost);
    margin-bottom: 2.5rem;
  }

  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-ghost);
    margin-bottom: 1rem;
  }

  .breadcrumb a {
    color: var(--teal);
    text-decoration: none;
  }

  .breadcrumb a:hover { color: var(--teal-bright); }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.875rem);
    font-weight: 600;
    color: var(--text-pure);
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin-bottom: 0.875rem;
  }

  .doc-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .doc-funder {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }

  .doc-sep {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-ghost);
  }

  .doc-program {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--text-ghost);
  }

  .doc-status {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    padding: 0.15rem 0.5rem;
    border-radius: 20px;
    border: 1px solid;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .status-active {
    color: var(--teal);
    border-color: var(--teal-border);
    background: var(--teal-subtle);
  }

  .status-dev {
    color: var(--text-ghost);
    border-color: var(--border-ghost);
    background: transparent;
  }

  /* Markdown body */
  .doc-body {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .doc-body :global(h1) { display: none; }

  .doc-body :global(h2) {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--text-pure);
    margin: 2.5rem 0 0.75rem;
    letter-spacing: -0.01em;
  }

  .doc-body :global(h3) {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 1.75rem 0 0.5rem;
  }

  .doc-body :global(h4) {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 1.5rem 0 0.5rem;
  }

  .doc-body :global(p) { margin-bottom: 1rem; }
  .doc-body :global(p:last-child) { margin-bottom: 0; }

  .doc-body :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .doc-body :global(em) {
    color: var(--text-tertiary);
    font-style: italic;
  }

  .doc-body :global(ul),
  .doc-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .doc-body :global(li) { line-height: 1.7; }

  .doc-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border-ghost);
    margin: 2rem 0;
  }

  .doc-body :global(blockquote) {
    border-left: 2px solid var(--border-medium);
    padding-left: 1rem;
    color: var(--text-tertiary);
    font-style: italic;
    margin: 1.5rem 0;
  }

  .doc-body :global(a) { color: var(--teal); }
  .doc-body :global(a:hover) { color: var(--teal-bright); }

  .doc-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
    display: block;
    overflow-x: auto;
  }

  .doc-body :global(th) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-ghost);
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border-subtle);
    text-align: left;
    white-space: nowrap;
  }

  .doc-body :global(td) {
    padding: 0.625rem 0.75rem;
    border-bottom: 1px solid var(--border-ghost);
    color: var(--text-secondary);
    vertical-align: top;
  }

  .doc-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: var(--void-elevated);
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    color: var(--teal);
  }

  @media (max-width: 640px) {
    .doc-page { padding: 2.5rem 1.25rem 4rem; }
  }
</style>

<script>
  const CORRECT = '2025';
  const STORAGE_KEY = 'pl_lab_auth';

  const gate = document.getElementById('gate');
  const content = document.getElementById('doc-content');
  const input = document.getElementById('gate-input') as HTMLInputElement;
  const error = document.getElementById('gate-error');

  function unlock() {
    if (gate) (gate as HTMLElement).style.display = 'none';
    if (content) (content as HTMLElement).style.display = 'block';
    localStorage.setItem(STORAGE_KEY, '1');
  }

  if (localStorage.getItem(STORAGE_KEY) === '1') unlock();

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      if (input.value === CORRECT) {
        unlock();
      } else {
        if (error) error.textContent = 'Incorrect.';
        input.value = '';
      }
    }
  });
</script>
